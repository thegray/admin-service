APP_ENV=development
PORT=8000
READ_TIMEOUT_SECONDS=5
WRITE_TIMEOUT_SECONDS=10
IDLE_TIMEOUT_SECONDS=120
SHUTDOWN_TIMEOUT_SECONDS=5
LOG_LEVEL=debug
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10
TOKEN_SECRET=dev-default-secret
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=admin
DB_SSLMODE=disable
